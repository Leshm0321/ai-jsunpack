AI_JSUNPACK_SERVICE_ROLE=browser-runner
AI_JSUNPACK_AUTH_SECRET=replace-with-a-shared-hmac-secret
AI_JSUNPACK_ARTIFACT_STORE=minio
AI_JSUNPACK_ARTIFACT_S3_BUCKET=ai-jsunpack-artifacts
AI_JSUNPACK_ARTIFACT_S3_PREFIX=browser-runner
AI_JSUNPACK_ARTIFACT_S3_ENDPOINT_URL=http://artifact-store:9000
AI_JSUNPACK_ARTIFACT_S3_REGION=us-east-1
AI_JSUNPACK_ARTIFACT_S3_ACCESS_KEY_ID=ai-jsunpack
AI_JSUNPACK_ARTIFACT_S3_SECRET_ACCESS_KEY=replace-with-minio-secret
AI_JSUNPACK_ARTIFACT_S3_ADDRESSING_STYLE=path
AI_JSUNPACK_BROWSER_RUNNER_NETWORK_POLICY=deny
AI_JSUNPACK_BROWSER_RUNNER_WORKDIR=/var/lib/ai-jsunpack/browser-runner
AI_JSUNPACK_BROWSER_RUNNER_QUEUE_BACKEND=postgresql
AI_JSUNPACK_BROWSER_RUNNER_QUEUE_DATABASE_URL=postgresql+psycopg://ai_jsunpack:ai_jsunpack@db:5432/ai_jsunpack
# Single-instance local fallback:
# AI_JSUNPACK_BROWSER_RUNNER_QUEUE_BACKEND=sqlite
# AI_JSUNPACK_BROWSER_RUNNER_DB_PATH=/var/lib/ai-jsunpack/browser-runner/browser-runs.sqlite3
AI_JSUNPACK_BROWSER_RUNNER_WORKERS=2
AI_JSUNPACK_BROWSER_RUNNER_MAX_ATTEMPTS=3
AI_JSUNPACK_BROWSER_RUNNER_LEASE_SECONDS=120
AI_JSUNPACK_BROWSER_RUNNER_RETRY_BACKOFF_SECONDS=1
AI_JSUNPACK_BROWSER_RUNNER_POLL_SECONDS=0.25

# Runtime smoke/compare execution profile. Worker requests are accepted only with
# Bearer tokens that include serviceRoles=["worker"]. Build/typecheck command
# execution still needs Worker sandbox configuration.
AI_JSUNPACK_BROWSER_RUNNER_ISOLATION_PROFILE=remote_browser_runner
AI_JSUNPACK_BROWSER_RUNNER_RUNTIME_NAME=playwright-remote
AI_JSUNPACK_BROWSER_RUNNER_RUNTIME_VERSION=
