# 复制为 deploy/env/production.env。绝不要提交已填充的 env 文件。
AI_JSUNPACK_API_IMAGE=ai-jsunpack/api:local
AI_JSUNPACK_WORKER_IMAGE=ai-jsunpack/worker:local
AI_JSUNPACK_BROWSER_RUNNER_IMAGE=ai-jsunpack/browser-runner:local
AI_JSUNPACK_WEB_IMAGE=ai-jsunpack/web:local
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest

AI_JSUNPACK_AUTH_SECRET=replace-with-a-long-random-hmac-secret
POSTGRES_DB=ai_jsunpack
POSTGRES_USER=ai_jsunpack
POSTGRES_PASSWORD=replace-with-database-password
AI_JSUNPACK_DATABASE_URL=postgresql+psycopg://ai_jsunpack:replace-with-url-encoded-password@db:5432/ai_jsunpack
MINIO_ROOT_USER=ai-jsunpack
MINIO_ROOT_PASSWORD=replace-with-minio-secret
AI_JSUNPACK_ARTIFACT_S3_BUCKET=ai-jsunpack-artifacts

# 使用共享 HMAC secret，通过 apps.api.app.auth.create_auth_token 生成以下 token。
AI_JSUNPACK_WEB_AUTH_TOKEN=replace-with-owner-user-token
AI_JSUNPACK_BROWSER_RUNNER_TOKEN=replace-with-worker-service-token

AI_JSUNPACK_WEB_BIND_ADDRESS=0.0.0.0
AI_JSUNPACK_WEB_PORT=8080
AI_JSUNPACK_WEB_USER_ID=docker-user
AI_JSUNPACK_WEB_PROJECT_ID=default
AI_JSUNPACK_CORS_ORIGINS=
AI_JSUNPACK_SANDBOX_VOLUME_NAME=ai-jsunpack-sandbox-workspaces
DOCKER_SOCKET_PATH=/var/run/docker.sock

AI_JSUNPACK_AGENT_PROVIDER=
AI_JSUNPACK_AGENT_MODEL=
AI_JSUNPACK_AGENT_BASE_URL=
AI_JSUNPACK_AGENT_API_KEY=
AI_JSUNPACK_LOCAL_AGENT_PROVIDER=
AI_JSUNPACK_LOCAL_AGENT_MODEL=
AI_JSUNPACK_LOCAL_AGENT_BASE_URL=
AI_JSUNPACK_LOCAL_AGENT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
OLLAMA_ENDPOINT=
