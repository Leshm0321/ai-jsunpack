# 当前 env 文件所属服务角色；Worker 启动时应为 worker。
AI_JSUNPACK_SERVICE_ROLE=worker

# 生产值必须从 secret manager 或 CI secret store 注入。
# 不要把解析后的 secret、模型 provider 凭据或 service token 烘焙进镜像。

# API、Worker、Browser Runner 共享的 HMAC 签名 secret，用于 Bearer token 校验。
AI_JSUNPACK_AUTH_SECRET=replace-with-a-shared-hmac-secret

# Ops heartbeat 过期时间，单位秒；超过后会在 ops metrics 中视为 stale。
AI_JSUNPACK_OPS_HEARTBEAT_TTL_SECONDS=90

# Worker 访问共享 Metadata DB 的 SQLAlchemy URL。
AI_JSUNPACK_DATABASE_URL=postgresql+psycopg://ai_jsunpack:ai_jsunpack@db:5432/ai_jsunpack

# Artifact Store 类型；Compose 部署使用 minio/S3 兼容存储。
AI_JSUNPACK_ARTIFACT_STORE=minio

# S3/MinIO bucket 名称，用于保存 source input、runtime evidence、报告和结果包。
AI_JSUNPACK_ARTIFACT_S3_BUCKET=ai-jsunpack-artifacts

# Worker 写入 artifact 时使用的 S3/MinIO key 前缀。
AI_JSUNPACK_ARTIFACT_S3_PREFIX=worker

# S3/MinIO endpoint；Compose 内部使用 artifact-store 服务名。
AI_JSUNPACK_ARTIFACT_S3_ENDPOINT_URL=http://artifact-store:9000

# S3/MinIO region；MinIO 通常使用 us-east-1 占位。
AI_JSUNPACK_ARTIFACT_S3_REGION=us-east-1

# S3/MinIO access key id；生产环境应从 secret manager 注入。
AI_JSUNPACK_ARTIFACT_S3_ACCESS_KEY_ID=ai-jsunpack

# S3/MinIO secret access key；这是 secret，生产环境必须替换。
AI_JSUNPACK_ARTIFACT_S3_SECRET_ACCESS_KEY=replace-with-minio-secret

# S3 地址风格；MinIO/Compose 默认使用 path-style。
AI_JSUNPACK_ARTIFACT_S3_ADDRESSING_STYLE=path

# 构建/类型检查使用的 sandbox runner 类型。当前可执行 runner：local、container、gvisor、firecracker。
# remote_browser_runner 只用于浏览器 runtime smoke/compare，不执行 Worker 构建/类型检查。
AI_JSUNPACK_SANDBOX_RUNNER=container

# container/gvisor runner 使用的基础镜像。
AI_JSUNPACK_SANDBOX_IMAGE=node:20-bookworm-slim

# gVisor 使用的 runsc runtime command。未设置时 Worker 会自动探测 docker/podman。
AI_JSUNPACK_SANDBOX_GVISOR_RUNTIME_COMMAND=

# Firecracker runner command；从 stdin 接收 JSON 请求，并在 stdout 返回 JSON 结果。
# 详见 deploy/firecracker/README.md。
# 示例形态：
# /usr/local/bin/ai-jsunpack-firecracker-launcher --kernel /srv/ai-jsunpack/firecracker/vmlinux --rootfs /srv/ai-jsunpack/firecracker/rootfs.ext4 --jailer /usr/bin/firecracker-jailer --firecracker /usr/bin/firecracker --socket-dir /run/ai-jsunpack/firecracker --wrapper-command /usr/local/bin/ai-jsunpack-firecracker-wrapper
AI_JSUNPACK_FIRECRACKER_RUNNER_COMMAND=

# sandbox runtime 名称，会写入构建/类型检查 resourcePolicy 审计证据。
AI_JSUNPACK_SANDBOX_RUNTIME_NAME=

# sandbox runtime 版本，会写入构建/类型检查 resourcePolicy 审计证据。
AI_JSUNPACK_SANDBOX_RUNTIME_VERSION=

# 可选：Browser Runner 服务 URL；设置后 runtime smoke/compare 委托给远程服务。
AI_JSUNPACK_BROWSER_RUNNER_URL=http://browser-runner:8000

# Worker 调用 Browser Runner 的 service Bearer token；必须带 serviceRoles=["worker"]。
AI_JSUNPACK_BROWSER_RUNNER_TOKEN=replace-with-worker-service-token
AI_JSUNPACK_BROWSER_RUNNER_TOKEN_FILE=

# Worker 轮询 Browser Runner 结果的间隔，单位秒。
AI_JSUNPACK_BROWSER_RUNNER_POLL_SECONDS=0.25

# Worker 等待 Browser Runner 单次 run 完成的超时时间，单位毫秒。
AI_JSUNPACK_BROWSER_RUNNER_TIMEOUT_MS=60000

# 云端模型 provider 名称，用于 Agent policy/audit 证据；CrewAI 实际 SDK 初始化仍看模型字符串和凭据。
AI_JSUNPACK_AGENT_PROVIDER=openai

# cloud_allowed 或 desensitized Job 使用的 CrewAI llm 模型字符串；为空时对应 Job 会产生 policy_denied/best-effort evidence。
AI_JSUNPACK_AGENT_MODEL=

# OpenAI-compatible 自定义云端/脱敏 Agent endpoint；provider=openai-compatible 且配置 base URL 时启用。
AI_JSUNPACK_AGENT_BASE_URL=

# OpenAI-compatible 自定义云端/脱敏 Agent endpoint secret；只注入 Worker，artifact 只记录是否配置。
AI_JSUNPACK_AGENT_API_KEY=

# 本地模型 provider 名称，用于 Agent policy/audit 证据。
AI_JSUNPACK_LOCAL_AGENT_PROVIDER=ollama

# local_only 或 desensitized Job 使用的本地 CrewAI llm 模型字符串。
AI_JSUNPACK_LOCAL_AGENT_MODEL=

# OpenAI-compatible 本地/私有 Agent endpoint；local provider=openai-compatible 且配置 base URL 时启用。
AI_JSUNPACK_LOCAL_AGENT_BASE_URL=

# OpenAI-compatible 本地/私有 Agent endpoint secret；本地服务可留空。
AI_JSUNPACK_LOCAL_AGENT_API_KEY=

# Agent 自定义 endpoint 请求超时，单位秒；未设置或无效时 Worker 使用 30。
AI_JSUNPACK_AGENT_TIMEOUT_SECONDS=30

# Agent 自定义 endpoint temperature；留空时不向 endpoint 发送 temperature。
AI_JSUNPACK_AGENT_TEMPERATURE=

# OpenAI provider 凭据；只注入 Worker，不要注入 API/Web/Browser Runner。
OPENAI_API_KEY=

# Anthropic provider 凭据；只注入 Worker，不要注入 API/Web/Browser Runner。
ANTHROPIC_API_KEY=

# Google/Gemini provider 凭据；只注入 Worker，不要注入 API/Web/Browser Runner。
GOOGLE_API_KEY=

# Azure OpenAI provider 凭据；只注入 Worker，不要注入 API/Web/Browser Runner。
AZURE_OPENAI_API_KEY=

# Ollama 服务地址，用于本地模型 provider。
OLLAMA_ENDPOINT=

# CrewAI 本地状态、缓存和运行时数据目录。
AI_JSUNPACK_CREWAI_DATA_ROOT=/var/lib/ai-jsunpack/crewai

# Docker Compose 使用 named volume，确保 host daemon 与 Worker 解析到同一个 attempt workspace。
AI_JSUNPACK_SANDBOX_WORKSPACE_ROOT=/var/lib/ai-jsunpack/sandbox-workspaces
AI_JSUNPACK_SANDBOX_VOLUME_NAME=ai-jsunpack-sandbox-workspaces

# Worker 实例 id，会写入 lease、ops heartbeat 和运行时证据。
AI_JSUNPACK_WORKER_ID=worker-local-1

# Job lease 持续时间，单位秒；Worker 超时后其他实例可恢复任务。
AI_JSUNPACK_WORKER_LEASE_SECONDS=300

# Worker 空闲轮询间隔，单位秒。
AI_JSUNPACK_WORKER_POLL_SECONDS=5

# 单个 Job 的最大 Worker 尝试次数。
AI_JSUNPACK_WORKER_MAX_ATTEMPTS=3
