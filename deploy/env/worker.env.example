AI_JSUNPACK_SERVICE_ROLE=worker
# Production values must be injected from a secret manager or CI secret store.
# Do not bake resolved secrets, model provider credentials, or service tokens into images.
AI_JSUNPACK_AUTH_SECRET=replace-with-a-shared-hmac-secret
AI_JSUNPACK_OPS_HEARTBEAT_TTL_SECONDS=90
AI_JSUNPACK_DATABASE_URL=postgresql+psycopg://ai_jsunpack:ai_jsunpack@db:5432/ai_jsunpack
AI_JSUNPACK_ARTIFACT_STORE=minio
AI_JSUNPACK_ARTIFACT_S3_BUCKET=ai-jsunpack-artifacts
AI_JSUNPACK_ARTIFACT_S3_PREFIX=worker
AI_JSUNPACK_ARTIFACT_S3_ENDPOINT_URL=http://artifact-store:9000
AI_JSUNPACK_ARTIFACT_S3_REGION=us-east-1
AI_JSUNPACK_ARTIFACT_S3_ACCESS_KEY_ID=ai-jsunpack
AI_JSUNPACK_ARTIFACT_S3_SECRET_ACCESS_KEY=replace-with-minio-secret
AI_JSUNPACK_ARTIFACT_S3_ADDRESSING_STYLE=path

# Build/typecheck sandbox runner.
# Supported executable runner today: local, container, gvisor, firecracker.
# Audit-only build profile without a configured adapter: remote_browser_runner.
# The remote_browser_runner profile is executable for runtime smoke/compare through AI_JSUNPACK_BROWSER_RUNNER_URL,
# but it does not execute build/typecheck commands in the Worker process.
AI_JSUNPACK_SANDBOX_RUNNER=container
AI_JSUNPACK_SANDBOX_IMAGE=node:20-bookworm-slim
# gVisor uses Docker/Podman with a configured runsc runtime. If omitted, Worker auto-detects docker/podman;
# set an empty value in a per-job buildValidation.gvisorRuntimeCommand to force sandbox_denied evidence.
AI_JSUNPACK_SANDBOX_GVISOR_RUNTIME_COMMAND=
# Firecracker runner command receives a JSON request on stdin and returns a JSON result on stdout.
# See deploy/firecracker/README.md. Example shape:
# /usr/local/bin/ai-jsunpack-firecracker-launcher --kernel /srv/ai-jsunpack/firecracker/vmlinux --rootfs /srv/ai-jsunpack/firecracker/rootfs.ext4 --jailer /usr/bin/firecracker-jailer --firecracker /usr/bin/firecracker --socket-dir /run/ai-jsunpack/firecracker --wrapper-command /usr/local/bin/ai-jsunpack-firecracker-wrapper
AI_JSUNPACK_FIRECRACKER_RUNNER_COMMAND=
AI_JSUNPACK_SANDBOX_RUNTIME_NAME=
AI_JSUNPACK_SANDBOX_RUNTIME_VERSION=

# Optional runtime smoke/compare delegation to the browser-runner service.
# Token must be a HMAC Bearer token with serviceRoles=["worker"] signed with AI_JSUNPACK_AUTH_SECRET.
AI_JSUNPACK_BROWSER_RUNNER_URL=http://browser-runner:8000
AI_JSUNPACK_BROWSER_RUNNER_TOKEN=replace-with-worker-service-token
AI_JSUNPACK_BROWSER_RUNNER_POLL_SECONDS=0.25
AI_JSUNPACK_BROWSER_RUNNER_TIMEOUT_MS=60000

AI_JSUNPACK_AGENT_MODEL=
AI_JSUNPACK_AGENT_PROVIDER=
AI_JSUNPACK_LOCAL_AGENT_MODEL=
AI_JSUNPACK_LOCAL_AGENT_PROVIDER=
AI_JSUNPACK_CREWAI_DATA_ROOT=/var/lib/ai-jsunpack/crewai
AI_JSUNPACK_WORKER_ID=worker-local-1
AI_JSUNPACK_WORKER_LEASE_SECONDS=300
AI_JSUNPACK_WORKER_POLL_SECONDS=5
AI_JSUNPACK_WORKER_MAX_ATTEMPTS=3
