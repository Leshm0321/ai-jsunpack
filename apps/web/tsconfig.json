{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist/types",
    "composite": true,
    "noEmit": true
  },
  "references": [
    { "path": "../../packages/shared" }
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}

