# 复制为 .env 用于本地开发，并替换 secret/token 占位值。
# 不要提交已填充的 .env 或任何生产 secret 值。

# API/Web/Worker/Browser Runner 共用的本地 HMAC 签名 secret，用于签发和校验 Bearer token。
AI_JSUNPACK_AUTH_SECRET=replace-with-local-dev-secret

# API 允许的浏览器跨域来源，多个来源用逗号分隔。
AI_JSUNPACK_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# 本地 Metadata DB 地址；默认使用 tmp/local-dev 下的 SQLite 文件。
AI_JSUNPACK_DATABASE_URL=sqlite:///tmp/local-dev/metadata.db

# 本地文件型 Artifact Store 的根目录。
AI_JSUNPACK_ARTIFACT_ROOT=tmp/local-dev/artifacts

# Artifact Store 类型；本地开发默认 local，部署环境通常使用 minio/S3 配置。
AI_JSUNPACK_ARTIFACT_STORE=local

# Ops heartbeat 过期时间，单位秒；超过后会在 ops metrics 中视为 stale。
AI_JSUNPACK_OPS_HEARTBEAT_TTL_SECONDS=90

# API 单次上传 source input 的最大字节数。
AI_JSUNPACK_MAX_UPLOAD_BYTES=104857600

# 可选：Ops alert webhook 地址；本地默认不投递。
AI_JSUNPACK_ALERT_WEBHOOK_URL=

# Ops alert webhook 投递超时时间，单位秒。
AI_JSUNPACK_ALERT_WEBHOOK_TIMEOUT_SECONDS=2

# 是否允许非 HTTPS webhook URL；本地调试才应设置。
AI_JSUNPACK_ALLOW_INSECURE_WEBHOOK_URLS=

# Web 调用的 API base URL。
VITE_API_BASE_URL=http://127.0.0.1:8000

# Web 本地用户 id，用于创建 Job 的 owner/user 上下文。
VITE_API_USER_ID=local-user

# Web 本地默认 project id；token 的 projects claim 需要包含该项目。
VITE_API_PROJECT_ID=default

# Web 调 API 使用的 Bearer token；为空时 scripts/dev.mjs web 会自动生成本地 owner token。
VITE_API_AUTH_TOKEN=

# 可选：仅供 Worker 使用的 Agent/CrewAI 配置。
# 根目录 .env 会被 npm run dev:api 一起加载；API strict mode 会拒绝
# Worker/model provider 配置，因此这里保持注释或空值。需要启用时，
# 请在 Worker 终端、deploy/env/worker.env.example 或 secret manager 中设置。
#
# cloud_allowed/desensitized Job 使用 AI_JSUNPACK_AGENT_* 或单个 Job 的 config.agentModel。
# local_only Job 使用 AI_JSUNPACK_LOCAL_AGENT_* 或单个 Job 的 config.localAgentModel。
# CrewAI 会把模型字符串作为 llm=<model> 使用；provider 凭据由 CrewAI/native
# provider 从各自的环境变量读取。
#
# 记录云端模型 provider 名称，用于 policy/audit 证据；实际 SDK 初始化仍看模型字符串和凭据。
# AI_JSUNPACK_AGENT_PROVIDER=openai
# 云端或脱敏模式使用的 CrewAI llm 模型字符串。
# AI_JSUNPACK_AGENT_MODEL=gpt-4o-mini
# 记录本地模型 provider 名称，用于 policy/audit 证据。
# AI_JSUNPACK_LOCAL_AGENT_PROVIDER=ollama
# local_only 或脱敏模式使用的本地 CrewAI llm 模型字符串。
# AI_JSUNPACK_LOCAL_AGENT_MODEL=ollama/llama3.1
# CrewAI 本地状态、缓存和运行时数据目录。
# AI_JSUNPACK_CREWAI_DATA_ROOT=.crewai-data
#
# 以下 provider 凭据示例只应放在 Worker 环境中：
# OpenAI provider 凭据。
# OPENAI_API_KEY=
# Anthropic provider 凭据。
# ANTHROPIC_API_KEY=
# Google/Gemini provider 凭据。
# GOOGLE_API_KEY=
# Azure OpenAI provider 凭据。
# AZURE_OPENAI_API_KEY=
# Ollama 服务地址。
# OLLAMA_ENDPOINT=http://127.0.0.1:11434
